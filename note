package commands

import (
	"fmt"
	"os"
	"strings"
	"time"

	"github.com/spf13/cobra"
)

; var MakeMigrationCmd = &cobra.Command{
; 	Use:   "make:migration [name]",
; 	Short: "Create a new migration SQL file",
; 	Args:  cobra.ExactArgs(1),
; 	Run: func(cmd *cobra.Command, args []string) {
; 		name := strings.ToLower(strings.ReplaceAll(args[0], " ", "_"))
; 		timestamp := time.Now().Format("20060102_150405")
; 		filename := fmt.Sprintf("migrations/%s_%s.sql", timestamp, name)

; 		// Make sure the folder exists
; 		if _, err := os.Stat("migrations"); os.IsNotExist(err) {
; 			err := os.Mkdir("migrations", 0755)
; 			if err != nil {
; 				fmt.Println("❌ Failed to create migrations folder:", err)
; 				return
; 			}
; 		}

; 		content := fmt.Sprintf("-- Migration: %s\n\n-- Write your SQL here\n", name)
; 		err := os.WriteFile(filename, []byte(content), 0644)
; 		if err != nil {
; 			fmt.Println("❌ Could not create migration file:", err)
; 			return
; 		}

; 		fmt.Println("✅ Migration file created:", filename)
; 	},
; }



