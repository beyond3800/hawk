create-table-users
CREATE TABLE IF NOT EXISTS users (
    id SERIAL PRIMARY KEY,
    name TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);





package commands

import (
	"database/sql"
	"fmt"
	"io/ioutil"
	"os"
	"path/filepath"
	"strings"

	"github.com/spf13/cobra"
	_ "github.com/lib/pq"
)

var MigrateCmd = &cobra.Command{
	Use:   "migrate",
	Short: "Run SQL migrations from the migrations/ folder",
	Run: func(cmd *cobra.Command, args []string) {
		conn := "user=postgres password=yourpassword dbname=my_custom_db sslmode=disable"

		db, err := sql.Open("postgres", conn)
		if err != nil {
			panic(err)
		}
		defer db.Close()

		files, err := ioutil.ReadDir("./migrations")
		if err != nil {
			fmt.Println("❌ Error reading migrations folder:", err)
			return
		}

		for _, file := range files {
			if !file.IsDir() && strings.HasSuffix(file.Name(), ".sql") {
				path := filepath.Join("./migrations", file.Name())
				sqlBytes, err := os.ReadFile(path)
				if err != nil {
					fmt.Println("❌ Failed to read", file.Name(), ":", err)
					continue
				}

				sqlStr := string(sqlBytes)
				fmt.Println("🚀 Running migration:", file.Name())
				_, err = db.Exec(sqlStr)
				if err != nil {
					fmt.Println("❌ Failed to execute", file.Name(), ":", err)
				} else {
					fmt.Println("✅ Success:", file.Name())
				}
			}
		}
	},
}




package main

import (
	"fmt"
	"yourapp/commands"

	"github.com/spf13/cobra"
)

; func main() {
; 	var rootCmd = &cobra.Command{Use: "goartisan"}

; 	rootCmd.AddCommand(commands.MigrateCmd)

; 	if err := rootCmd.Execute(); err != nil {
